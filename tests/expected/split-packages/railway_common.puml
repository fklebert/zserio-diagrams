@startuml railway_common

' Generated by zserio-diagram extension
skinparam classAttributeIconSize 0
hide empty members

package "railway.common" {
  enum TrackGauge <<enum>> {
    STANDARD
    NARROW
    BROAD
  }

  class GeoPosition <<struct>> {
    +int32 latitudeE7
    +int32 longitudeE7
    ~int16 altitudeMeters
  }

  class TimeOfDay <<struct>> {
    +bit:5 hour
    +bit:6 minute
  }

}

RailNetwork *-- "2" GeoPosition : boundingBox
Station *-- "1" GeoPosition : position
TrackSegment --> "1" TrackGauge : gauge
TimetableStop *-- "1" TimeOfDay : arrival
TimetableStop *-- "1" TimeOfDay : departure

@enduml
