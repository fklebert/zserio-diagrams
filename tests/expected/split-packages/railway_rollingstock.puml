@startuml railway_rollingstock

' Generated by zserio-diagram extension
skinparam classAttributeIconSize 0
hide empty members

package "railway.rollingstock" {
  enum Amenities <<bitmask>> {
    WIFI
    POWER_SOCKETS
    AIR_CONDITIONING
    BISTRO
    WHEELCHAIR_ACCESS
  }

  enum TractionType <<enum>> {
    DIESEL
    ELECTRIC
    HYBRID
    STEAM
  }

  class Locomotive <<struct>> {
    +string designation
    +TractionType traction
    +uint16 powerKw
  }

  class PassengerCar <<struct>> {
    +uint16 seatCount
    +Amenities amenities
  }

  class FreightCar <<struct>> {
    +uint32 maxLoadKg
    +bool hazardousGoods
  }

  class CarBody <<union>> {
    +PassengerCar passenger
    +FreightCar freight
  }

  class Car <<struct>> {
    +uint32 tareWeightKg
    +CarBody body
  }

  class TrainComposition <uint8 carCount> <<struct>> {
    +Car[] cars
  }

  class Train <<struct>> {
    +TrainId id
    ~string name
    +Locomotive locomotive
    +uint8 carCount
    +TrainComposition composition
  }

}

RailwayDatabase *-- "*" Train : fleet
Locomotive --> "1" TractionType : traction
PassengerCar --> "1" Amenities : amenities
CarBody *-- "1" PassengerCar : passenger
CarBody *-- "1" FreightCar : freight
Car *-- "1" CarBody : body
TrainComposition *-- "*" Car : cars
Train *-- "1" Locomotive : locomotive
Train *-- "1" TrainComposition : composition

@enduml
