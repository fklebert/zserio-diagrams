@startuml railway_signalling

' Generated by zserio-diagram extension
skinparam classAttributeIconSize 0
hide empty members

package "railway.signalling" {
  enum SignalType <<enum>> {
    MAIN
    DISTANT
    SHUNTING
  }

  enum MainAspect <<enum>> {
    STOP
    CLEAR
    CAUTION
  }

  enum DistantAspect <<enum>> {
    EXPECT_STOP
    EXPECT_CLEAR
  }

  enum ShuntingAspect <<enum>> {
    HALT
    PROCEED
  }

  class SignalState <SignalType type> <<choice>> {
    +MainAspect mainAspect
    +DistantAspect distantAspect
    +ShuntingAspect shuntingAspect
  }

  class Signal <<struct>> {
    +TrackId track
    +uint32 positionMeters
    +SignalType type
    +SignalState state
  }

}

RailwayDatabase *-- "*" Signal : signals
SignalState --> "1" MainAspect : mainAspect
SignalState --> "1" DistantAspect : distantAspect
SignalState --> "1" ShuntingAspect : shuntingAspect
Signal --> "1" SignalType : type
Signal *-- "1" SignalState : state

@enduml
