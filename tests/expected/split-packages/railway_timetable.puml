@startuml railway_timetable

' Generated by zserio-diagram extension
skinparam classAttributeIconSize 0
hide empty members

package "railway.timetable" {
  enum OperatingDays <<bitmask>> {
    MONDAY
    TUESDAY
    WEDNESDAY
    THURSDAY
    FRIDAY
    SATURDAY
    SUNDAY
  }

  enum ServiceCategory <<enum>> {
    REGIONAL
    INTERCITY
    HIGH_SPEED
    NIGHT
    FREIGHT
  }

  class Timetable <<struct>> {
    +string validityPeriod
    +Service[] services
  }

  class Service <<struct>> {
    +TrainId trainId
    +ServiceCategory category
    +OperatingDays operatingDays
    +TimetableStop[] stops
  }

  class TimetableStop <<struct>> {
    +StationId station
    +TimeOfDay arrival
    +TimeOfDay departure
    ~uint8 platformNumber
  }

}

RailwayDatabase *-- "1" Timetable : timetable
Timetable *-- "*" Service : services
Service --> "1" ServiceCategory : category
Service --> "1" OperatingDays : operatingDays
Service *-- "*" TimetableStop : stops
TimetableStop *-- "1" TimeOfDay : arrival
TimetableStop *-- "1" TimeOfDay : departure

@enduml
