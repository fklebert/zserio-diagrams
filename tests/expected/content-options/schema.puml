@startuml schema

' Generated by zserio-diagram extension
left to right direction
skinparam linetype ortho
skinparam classAttributeIconSize 0
hide empty members

package "railway" {
  class RailwayDatabase <<struct>> {
    +RailNetwork network
    +Train[] fleet
    +Signal[] signals
    +Timetable timetable
  }

}

package "railway.network" {
  class RailNetwork <<struct>> {
    +string name
    +GeoPosition[] boundingBox
    +Station[] stations
    +TrackSegment[] segments
  }

  class Station <<struct>> {
    +StationId id
    +string name
    +GeoPosition position
    +Platform[] platforms
  }

  class Platform <<struct>> {
    +uint8 number
    +uint16 lengthMeters
    +bool hasShelter
  }

  class TrackSegment <<struct>> {
    +TrackId id
    +StationId fromStation
    +StationId toStation
    +TrackGauge gauge
    +Electrification electrification
    +uint32 lengthMeters
    ~SpeedRestriction speedRestriction
  }

  enum Electrification <<enum>> {
    NONE
    DC_1500V
    DC_3000V
    AC_15KV_16_7HZ
    AC_25KV_50HZ
  }

  class SpeedRestriction <<struct>> {
    +uint16 maxSpeedKmh
    +string reason
  }

}

package "railway.common" {
  class StationId <<subtype>> {
    alias of uint32
  }

  class TrackId <<subtype>> {
    alias of uint32
  }

  class TrainId <<subtype>> {
    alias of uint16
  }

  class MAX_PLATFORMS <<const>> {
    {static} uint8 = zserio.ast.Expression@c540f5a
  }

  enum TrackGauge <<enum>> {
    STANDARD
    NARROW
    BROAD
  }

  class GeoPosition <<struct>> {
    +int32 latitudeE7
    +int32 longitudeE7
    ~int16 altitudeMeters
  }

  class TimeOfDay <<struct>> {
    +bit:5 hour
    +bit:6 minute
  }

}

package "railway.rollingstock" {
  enum Amenities <<bitmask>> {
    WIFI
    POWER_SOCKETS
    AIR_CONDITIONING
    BISTRO
    WHEELCHAIR_ACCESS
  }

  enum TractionType <<enum>> {
    DIESEL
    ELECTRIC
    HYBRID
    STEAM
  }

  class Locomotive <<struct>> {
    +string designation
    +TractionType traction
    +uint16 powerKw
  }

  class PassengerCar <<struct>> {
    +uint16 seatCount
    +Amenities amenities
  }

  class FreightCar <<struct>> {
    +uint32 maxLoadKg
    +bool hazardousGoods
  }

  class CarBody <<union>> {
    +PassengerCar passenger
    +FreightCar freight
  }

  class Car <<struct>> {
    +uint32 tareWeightKg
    +CarBody body
  }

  class TrainComposition <uint8 carCount> <<struct>> {
    +Car[] cars
  }

  class Train <<struct>> {
    +TrainId id
    ~string name
    +Locomotive locomotive
    +uint8 carCount
    +TrainComposition composition
  }

}

package "railway.signalling" {
  enum SignalType <<enum>> {
    MAIN
    DISTANT
    SHUNTING
  }

  enum MainAspect <<enum>> {
    STOP
    CLEAR
    CAUTION
  }

  enum DistantAspect <<enum>> {
    EXPECT_STOP
    EXPECT_CLEAR
  }

  enum ShuntingAspect <<enum>> {
    HALT
    PROCEED
  }

  class SignalState <SignalType type> <<choice>> {
    +MainAspect mainAspect
    +DistantAspect distantAspect
    +ShuntingAspect shuntingAspect
  }

  class Signal <<struct>> {
    +TrackId track
    +uint32 positionMeters
    +SignalType type
    +SignalState state
  }

}

package "railway.timetable" {
  enum OperatingDays <<bitmask>> {
    MONDAY
    TUESDAY
    WEDNESDAY
    THURSDAY
    FRIDAY
    SATURDAY
    SUNDAY
  }

  enum ServiceCategory <<enum>> {
    REGIONAL
    INTERCITY
    HIGH_SPEED
    NIGHT
    FREIGHT
  }

  class Timetable <<struct>> {
    +string validityPeriod
    +Service[] services
  }

  class Service <<struct>> {
    +TrainId trainId
    +ServiceCategory category
    +OperatingDays operatingDays
    +TimetableStop[] stops
  }

  class TimetableStop <<struct>> {
    +StationId station
    +TimeOfDay arrival
    +TimeOfDay departure
    ~uint8 platformNumber
  }

}

RailwayDatabase *-- "1" RailNetwork : network
RailwayDatabase *-- "*" Train : fleet
RailwayDatabase *-- "*" Signal : signals
RailwayDatabase *-- "1" Timetable : timetable
RailNetwork *-- "2" GeoPosition : boundingBox
RailNetwork *-- "*" Station : stations
RailNetwork *-- "*" TrackSegment : segments
Station *-- "1" StationId : id
Station *-- "1" GeoPosition : position
Station *-- "*" Platform : platforms
