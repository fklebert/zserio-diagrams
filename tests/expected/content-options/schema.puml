TrackSegment *-- "1" StationId : fromStation
TrackSegment *-- "1" StationId : toStation
TrackSegment --> "1" TrackGauge : gauge
TrackSegment --> "1" Electrification : electrification
TrackSegment *-- "0..1" SpeedRestriction : speedRestriction
Locomotive --> "1" TractionType : traction
PassengerCar --> "1" Amenities : amenities
CarBody *-- "1" PassengerCar : passenger
CarBody *-- "1" FreightCar : freight
Car *-- "1" CarBody : body
TrainComposition *-- "*" Car : cars
Train *-- "1" TrainId : id
Train *-- "1" Locomotive : locomotive
Train *-- "1" TrainComposition : composition
SignalState --> "1" MainAspect : mainAspect
SignalState --> "1" DistantAspect : distantAspect
SignalState --> "1" ShuntingAspect : shuntingAspect
Signal *-- "1" TrackId : track
Signal --> "1" SignalType : type
Signal *-- "1" SignalState : state
Timetable *-- "*" Service : services
Service *-- "1" TrainId : trainId
Service --> "1" ServiceCategory : category
Service --> "1" OperatingDays : operatingDays
Service *-- "*" TimetableStop : stops
TimetableStop *-- "1" StationId : station
TimetableStop *-- "1" TimeOfDay : arrival
TimetableStop *-- "1" TimeOfDay : departure

@enduml
